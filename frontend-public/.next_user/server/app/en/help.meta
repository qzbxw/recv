{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[locale]/layout,_N_T_/[locale]/help/layout,_N_T_/[locale]/help/page,_N_T_/en/help"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$locale/help/__PAGE__",
    "/$d$locale/help",
    "/$d$locale",
    "/_index",
    "/_head"
  ]
}