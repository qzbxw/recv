29:["$","article","11. LIMITATION OF LIABILITY",{"className":"lend-card relative p-8 md:p-10 group hover:border-accent/20 transition-colors duration-500","children":[["$","div",null,{"className":"flex items-baseline gap-4 mb-5","children":[["$","span",null,{"className":"text-sm font-black text-accent/40 font-['Montserrat'] tabular-nums","children":"11"}],["$","h2",null,{"className":"text-xl md:text-2xl font-bold tracking-tight text-white","children":"11. LIMITATION OF LIABILITY"}]]}],["$","div",null,{"className":"pl-0 md:pl-9","children":[[["$","p","IN NO EVENT SHALL THE COMPANY, ITS FOUNDERS, CORE DEVELOPERS, DIRECTORS, OR AFFILIATES BE LIABLE FOR ANY PUNITIVE, INCIDENTAL, SPECIAL, CONSEQUENTIAL, OR EXEMPLARY DAMAGES, INCLUDING BUT NOT LIMITED TO LOSS OF PROFITS, LOSS OF REVENUE, LOSS OF DIGITAL ASSETS, OR CORRUPTION OF DATA.",{"className":"text-white/55 leading-[1.8] mb-4 last:mb-0","children":"IN NO EVENT SHALL THE COMPANY, ITS FOUNDERS, CORE DEVELOPERS, DIRECTORS, OR AFFILIATES BE LIABLE FOR ANY PUNITIVE, INCIDENTAL, SPECIAL, CONSEQUENTIAL, OR EXEMPLARY DAMAGES, INCLUDING BUT NOT LIMITED TO LOSS OF PROFITS, LOSS OF REVENUE, LOSS OF DIGITAL ASSETS, OR CORRUPTION OF DATA."}],["$","p","UNDER NO CIRCUMSTANCES SHALL THE COMPANY'S TOTAL CUMULATIVE LIABILITY TO YOU FOR ANY AND ALL CLAIMS EXCEED THE TOTAL AMOUNT OF SUBSCRIPTION FEES PAID BY YOU TO THE COMPANY IN THE THREE (3) MONTHS IMMEDIATELY PRECEDING THE EVENT GIVING RISE TO THE CLAIM. IF YOU ARE ON A FREE PLAN, THE AGGREGATE LIABILITY SHALL BE STRICTLY LIMITED TO ZERO DOLLARS ($0.00).",{"className":"text-white/55 leading-[1.8] mb-4 last:mb-0","children":"UNDER NO CIRCUMSTANCES SHALL THE COMPANY'S TOTAL CUMULATIVE LIABILITY TO YOU FOR ANY AND ALL CLAIMS EXCEED THE TOTAL AMOUNT OF SUBSCRIPTION FEES PAID BY YOU TO THE COMPANY IN THE THREE (3) MONTHS IMMEDIATELY PRECEDING THE EVENT GIVING RISE TO THE CLAIM. IF YOU ARE ON A FREE PLAN, THE AGGREGATE LIABILITY SHALL BE STRICTLY LIMITED TO ZERO DOLLARS ($0.00)."}]],null]}]]}]
2a:["$","article","12. INDEMNIFICATION",{"className":"lend-card relative p-8 md:p-10 group hover:border-accent/20 transition-colors duration-500","children":[["$","div",null,{"className":"flex items-baseline gap-4 mb-5","children":[["$","span",null,{"className":"text-sm font-black text-accent/40 font-['Montserrat'] tabular-nums","children":"12"}],["$","h2",null,{"className":"text-xl md:text-2xl font-bold tracking-tight text-white","children":"12. INDEMNIFICATION"}]]}],["$","div",null,{"className":"pl-0 md:pl-9","children":[[["$","p","You agree to defend, indemnify, and hold harmless the Company and its affiliates from and against any claims, actions, demands, liabilities, damages, and expenses arising from your breach of this Agreement, violation of law, or any dispute between you and your Customers.",{"className":"text-white/55 leading-[1.8] mb-4 last:mb-0","children":"You agree to defend, indemnify, and hold harmless the Company and its affiliates from and against any claims, actions, demands, liabilities, damages, and expenses arising from your breach of this Agreement, violation of law, or any dispute between you and your Customers."}]],null]}]]}]
2b:["$","article","13. GOVERNING LAW AND DISPUTE RESOLUTION",{"className":"lend-card relative p-8 md:p-10 group hover:border-accent/20 transition-colors duration-500","children":[["$","div",null,{"className":"flex items-baseline gap-4 mb-5","children":[["$","span",null,{"className":"text-sm font-black text-accent/40 font-['Montserrat'] tabular-nums","children":"13"}],["$","h2",null,{"className":"text-xl md:text-2xl font-bold tracking-tight text-white","children":"13. GOVERNING LAW AND DISPUTE RESOLUTION"}]]}],["$","div",null,{"className":"pl-0 md:pl-9","children":[[["$","p","13.1. This Agreement is governed by the laws of Cyprus, without regard to its conflict-of-laws rules.",{"className":"text-white/55 leading-[1.8] mb-4 last:mb-0","children":"13.1. This Agreement is governed by the laws of Cyprus, without regard to its conflict-of-laws rules."}],["$","p","13.2. Before commencing formal proceedings, a party must send written notice describing the dispute to legal@recv.money. The parties shall attempt in good faith to resolve the dispute within thirty (30) days.",{"className":"text-white/55 leading-[1.8] mb-4 last:mb-0","children":"13.2. Before commencing formal proceedings, a party must send written notice describing the dispute to legal@recv.money. The parties shall attempt in good faith to resolve the dispute within thirty (30) days."}],["$","p","13.3. Any dispute not resolved under Section 13.2 shall be finally resolved by the competent courts of Nicosia, Cyprus, in the English language, under the rules in effect when the proceeding begins.",{"className":"text-white/55 leading-[1.8] mb-4 last:mb-0","children":"13.3. Any dispute not resolved under Section 13.2 shall be finally resolved by the competent courts of Nicosia, Cyprus, in the English language, under the rules in effect when the proceeding begins."}],["$","p","13.4. Nothing in this Section prevents either party from seeking urgent injunctive relief or exercising rights that cannot lawfully be waived.",{"className":"text-white/55 leading-[1.8] mb-4 last:mb-0","children":"13.4. Nothing in this Section prevents either party from seeking urgent injunctive relief or exercising rights that cannot lawfully be waived."}]],null]}]]}]
2c:["$","article","14. SEVERABILITY AND ENTIRE AGREEMENT",{"className":"lend-card relative p-8 md:p-10 group hover:border-accent/20 transition-colors duration-500","children":[["$","div",null,{"className":"flex items-baseline gap-4 mb-5","children":[["$","span",null,{"className":"text-sm font-black text-accent/40 font-['Montserrat'] tabular-nums","children":"14"}],["$","h2",null,{"className":"text-xl md:text-2xl font-bold tracking-tight text-white","children":"14. SEVERABILITY AND ENTIRE AGREEMENT"}]]}],["$","div",null,{"className":"pl-0 md:pl-9","children":[[["$","p","If any provision of this Agreement is found to be unenforceable or invalid, that provision shall be limited or eliminated to the minimum extent necessary so that this Agreement shall otherwise remain in full force and effect. This Agreement constitutes the entire agreement between the parties.",{"className":"text-white/55 leading-[1.8] mb-4 last:mb-0","children":"If any provision of this Agreement is found to be unenforceable or invalid, that provision shall be limited or eliminated to the minimum extent necessary so that this Agreement shall otherwise remain in full force and effect. This Agreement constitutes the entire agreement between the parties."}]],null]}]]}]
