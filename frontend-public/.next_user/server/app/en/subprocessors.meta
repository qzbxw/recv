{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[locale]/layout,_N_T_/[locale]/subprocessors/layout,_N_T_/[locale]/subprocessors/page,_N_T_/en/subprocessors"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$locale/subprocessors/__PAGE__",
    "/$d$locale/subprocessors",
    "/$d$locale",
    "/_index",
    "/_head"
  ]
}