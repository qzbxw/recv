2d:["$","pre",null,{"className":"rounded-2xl bg-[#0a0a0c] border border-white/10 p-5 md:p-6 overflow-x-auto my-8 text-white/80 [&>code]:bg-transparent [&>code]:border-0 [&>code]:p-0 [&>code]:text-white/80","children":["$","code",null,{"className":"language-bash","children":"curl -X POST https://recv.money/v1/invoices \\\n  -H \"X-API-Key: $RECV_API_KEY\" \\\n  -H \"Content-Type: application/json\" \\\n  -H \"Idempotency-Key: order-1001\" \\\n  -d '{\n    \"title\": \"Order #1001\",\n    \"base_amount_usd\": \"49.00\",\n    \"payable_network\": \"TRON\",\n    \"expires_in_minutes\": 60\n  }'\n"}]}]
