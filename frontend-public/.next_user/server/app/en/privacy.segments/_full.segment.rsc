1a:["$","section",null,{"className":"pb-24","data-reveal":true,"children":["$","div",null,{"className":"container mx-auto px-6 max-w-3xl flex flex-col gap-5 lend-reveal--2","children":[["$","article","1. PREAMBLE AND SCOPE",{"className":"lend-card relative p-8 md:p-10 group hover:border-accent/20 transition-colors duration-500","children":[["$","div",null,{"className":"flex items-baseline gap-4 mb-5","children":[["$","span",null,{"className":"text-sm font-black text-accent/40 font-['Montserrat'] tabular-nums","children":"01"}],["$","h2",null,{"className":"text-xl md:text-2xl font-bold tracking-tight text-white","children":"1. PREAMBLE AND SCOPE"}]]}],["$","div",null,{"className":"pl-0 md:pl-9","children":[[["$","p","This Privacy Policy (the \"Policy\") governs how recv (\"Company\", \"we\", \"us\", \"our\") collects, processes, utilizes, and safeguards information when you (\"Merchant\", \"User\", \"you\") or your end-users (\"Customers\") interact with our software-as-a-service infrastructure, Telegram bots, API endpoints, and public checkout interfaces (collectively, the \"Service\").",{"className":"text-white/55 leading-[1.8] mb-4 last:mb-0","children":"This Privacy Policy (the \"Policy\") governs how recv (\"Company\", \"we\", \"us\", \"our\") collects, processes, utilizes, and safeguards information when you (\"Merchant\", \"User\", \"you\") or your end-users (\"Customers\") interact with our software-as-a-service infrastructure, Telegram bots, API endpoints, and public checkout interfaces (collectively, the \"Service\")."}],["$","p","This Policy is designed to comply with global data protection principles while explicitly acknowledging the inherently public, immutable, and decentralized nature of cryptographic blockchain technology.",{"className":"text-white/55 leading-[1.8] mb-4 last:mb-0","children":"This Policy is designed to comply with global data protection principles while explicitly acknowledging the inherently public, immutable, and decentralized nature of cryptographic blockchain technology."}]],null]}]]}],["$","article","2. THE FUNDAMENTAL REALITY OF BLOCKCHAIN DATA (CRITICAL NOTICE)",{"className":"lend-card relative p-8 md:p-10 group hover:border-accent/20 transition-colors duration-500","children":[["$","div",null,{"className":"flex items-baseline gap-4 mb-5","children":[["$","span",null,{"className":"text-sm font-black text-accent/40 font-['Montserrat'] tabular-nums","children":"02"}],["$","h2",null,{"className":"text-xl md:text-2xl font-bold tracking-tight text-white","children":"2. THE FUNDAMENTAL REALITY OF BLOCKCHAIN DATA (CRITICAL NOTICE)"}]]}],["$","div",null,{"className":"pl-0 md:pl-9","children":[[["$","p","2.1. Public Ledgers: You and your Customers expressly acknowledge that blockchain networks (including but not limited to TON, TRON, Solana, Base, Arbitrum, and BSC) are decentralized, public ledgers.",{"className":"text-white/55 leading-[1.8] mb-4 last:mb-0","children":"2.1. Public Ledgers: You and your Customers expressly acknowledge that blockchain networks (including but not limited to TON, TRON, Solana, Base, Arbitrum, and BSC) are decentralized, public ledgers."}],["$","p","2.2. No Expectation of Privacy On-Chain: Wallet addresses, transaction hashes (TXIDs), timestamps, transfer amounts, and on-chain memos/comments are permanently recorded and accessible to anyone globally. The Company does not control these networks and cannot erase, obfuscate, or alter on-chain data.",{"className":"text-white/55 leading-[1.8] mb-4 last:mb-0","children":"2.2. No Expectation of Privacy On-Chain: Wallet addresses, transaction hashes (TXIDs), timestamps, transfer amounts, and on-chain memos/comments are permanently recorded and accessible to anyone globally. The Company does not control these networks and cannot erase, obfuscate, or alter on-chain data."}],"$L1d"],null]}]]}],"$L1e","$L1f","$L20","$L21","$L22","$L23","$L24","$L25"]}]}]
