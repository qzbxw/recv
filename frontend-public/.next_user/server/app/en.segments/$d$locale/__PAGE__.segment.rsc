7:T941,{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"How does recv ensure the security of my funds?","acceptedAnswer":{"@type":"Answer","text":"We utilize a non-custodial architecture. This means your private keys never leave your device, and funds are sent directly from the client to your address. recv only monitors the blockchain and provides transaction notifications."}},{"@type":"Question","name":"Which networks and assets are currently supported?","acceptedAnswer":{"@type":"Answer","text":"We currently support TON (native and USDT), TRON, Solana, Base, Arbitrum, and BSC. We are continuously adding new liquid protocols based on business-tier demands."}},{"@type":"Question","name":"Can I automate the delivery of digital goods?","acceptedAnswer":{"@type":"Answer","text":"Absolutely. Our Webhook system provides instantaneous notifications to your server upon payment confirmation, enabling full automation of access, subscriptions, or digital delivery."}},{"@type":"Question","name":"How are underpayments or incorrect amounts handled?","acceptedAnswer":{"@type":"Answer","text":"recv intelligently detects any deviations from the expected amount. If an underpayment occurs, the transaction is flagged as 'Underpaid,' allowing you to either request the balance or manually approve the order."}},{"@type":"Question","name":"Do I need to pass KYC to start using recv?","acceptedAnswer":{"@type":"Answer","text":"No. Since we operate strictly as non-custodial middleware and do not hold or process fiat currency, we do not require KYC verification from merchants. You can start accepting crypto immediately."}},{"@type":"Question","name":"Is there a limit on how many invoices I can create?","acceptedAnswer":{"@type":"Answer","text":"Paid subscription plans have absolutely no limits on manual invoice creation. However, the free Trial plan has a lifetime limit of 15 live invoices. You can upgrade to any paid plan to unlock unlimited invoices."}},{"@type":"Question","name":"What happens if a network (e.g., TRON) goes down?","acceptedAnswer":{"@type":"Answer","text":"Our watchers are distributed across multiple global RPC providers. If a network halts, recv queues the monitoring tasks. Once the blockchain resumes block production, all pending transactions will be automatically verified and webhooks fired."}}]}0:{"rsc":["$","$1","c",{"children":[["$","$L2",null,{"children":["$","div",null,{"className":"lend-page min-h-screen bg-black text-white selection:bg-purple-500/30","children":[["$","$3",null,{"fallback":null,"children":["$","$L4",null,{}]}],["$","$L5",null,{}],["$","div",null,{"className":"lend-backdrop lend-backdrop--grid"}],["$","div",null,{"className":"lend-backdrop lend-backdrop--glow lend-backdrop--left"}],["$","div",null,{"className":"lend-backdrop lend-backdrop--glow lend-backdrop--right"}],["$","$L6",null,{"language":"en","nav":{"products":{"title":"Products","checkout":{"title":"Checkout","desc":"High-converting payment UI"},"api":{"title":"API","desc":"Infrastructure for developers"},"invoicing":{"title":"Invoicing","desc":"Professional billing tools"},"mcp":{"title":"MCP Agent","desc":"Autonomous AI agent tools"}},"useCases":{"title":"Use Cases","tgShops":"Telegram Shops","saas":"SaaS Billing","digital":"Digital Goods","communities":"Paid Communities"},"networks":{"title":"Networks","ton":"TON","ton_usdt":"TON USDT","tron":"TRON","solana":"Solana","base":"Base","bsc":"BSC","arbitrum":"Arbitrum"},"pricing":{"title":"Pricing","merchant":"Merchant","developer":"Developer","business":"Business"},"docs":"Docs","blog":"Blog","console":"Console"}}],["$","main",null,{"className":"lend-shell relative z-10 pt-40 min-h-[calc(100vh-200px)]","children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Organization\",\"name\":\"recv\",\"url\":\"https://recv.money\",\"logo\":\"https://recv.money/logo.png\"}"}}],["$"