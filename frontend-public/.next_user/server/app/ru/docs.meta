{
  "status": 307,
  "headers": {
    "location": "/ru/docs/introduction",
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[locale]/layout,_N_T_/[locale]/docs/layout,_N_T_/[locale]/docs/page,_N_T_/ru/docs"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$locale/docs/__PAGE__",
    "/$d$locale/docs",
    "/$d$locale",
    "/_index",
    "/_head"
  ]
}