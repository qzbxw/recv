{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[locale]/layout,_N_T_/[locale]/merchant/layout,_N_T_/[locale]/merchant/page,_N_T_/ru/merchant"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$locale/merchant/__PAGE__",
    "/$d$locale/merchant",
    "/$d$locale",
    "/_index",
    "/_head"
  ]
}