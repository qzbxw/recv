f:["$","section",null,{"id":"faq","className":"py-32 border-t border-white/[0.04]","data-reveal":true,"children":["$","div",null,{"className":"container mx-auto px-6 max-w-5xl","children":[["$","div",null,{"className":"lend-reveal--1 mb-24 text-center","children":[["$","span",null,{"className":"lend-section-kicker justify-center mx-auto","children":"FAQ"}],["$","h2",null,{"className":"text-4xl md:text-6xl font-bold tracking-tight text-white font-['Montserrat']","children":"Frequently Asked Questions"}]]}],["$","div",null,{"className":"lend-reveal--2 max-w-4xl mx-auto","children":["$","$L1b",null,{"items":[{"question":"How exactly do the crypto webhooks function?","answer":"When a customer initiates a transfer, our Watchers monitor the respective blockchain. Once the transaction reaches the required confirmations, recv fires a JSON payload via HTTP POST to your pre-configured endpoint with the invoice ID, amount, and TX hash."},{"question":"How does the API handle network congestion?","answer":"recv uses redundant RPC access for supported networks. If a public node drops, we fail over to backup providers. During congestion, watchers maintain state and deliver the webhook when the payment is finalized on-chain."},{"question":"What is idempotency and why is it critical for crypto payments?","answer":"Idempotency ensures that no matter how many times a specific API request or webhook is retried (due to network drops or client errors), the end result is the same. In crypto, this is vital to prevent 'double-spending' or granting a user a premium subscription twice for a single blockchain transaction."},{"question":"Can I generate unique deposit addresses for every single user?","answer":"recv API utilizes a smart-matching protocol rather than generating unique wallet addresses per invoice (which is expensive and difficult to sweep). We use mathematically unique decimal suffixes (e.g., 100.000123 USDT) or network-native memos (on TON) to map a single incoming transaction on your master wallet to a specific user invoice instantly."},{"question":"Is there an SDK available for Node.js or Python?","answer":"Currently, we provide a heavily documented, language-agnostic RESTful API that can be consumed by any modern HTTP client (Axios, Fetch, Requests). Official SDKs for TypeScript/Node.js and Go are actively in development."},{"question":"How do I verify that a webhook actually came from recv?","answer":"Every webhook includes an 'X-recv-Signature' header. You must use your secret Webhook Key to compute an HMAC-SHA256 hash of the raw request body. If your computed hash matches our header, the payload is authentic and untampered."},{"question":"What happens if I exceed my 50,000 monthly API requests limit?","answer":"We do not hard-block your API if you hit a spike. You will receive an automated alert via email and Telegram as you approach the limit (80% and 100%). Overages may be billed at a nominal rate, or you can seamlessly upgrade to the Business plan."},{"question":"Do you offer technical support for API integration?","answer":"Yes. Developer plan subscribers have access to prioritized email support and a dedicated developer community channel where our core engineers actively assist with architecture design and debugging."}],"eyebrow":"Plan Detail","triggerClassName":"flex items-center justify-between","questionClassName":"text-white font-['Montserrat']","answerClassName":"text-white/60"}]}]]}]}]
