7:Tc32,{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"How exactly do the crypto webhooks function?","acceptedAnswer":{"@type":"Answer","text":"When a customer initiates a transfer, our Watchers monitor the respective blockchain. Once the transaction reaches the required confirmations, recv fires a JSON payload via HTTP POST to your pre-configured endpoint with the invoice ID, amount, and TX hash."}},{"@type":"Question","name":"How does the API handle network congestion?","acceptedAnswer":{"@type":"Answer","text":"recv uses redundant RPC access for supported networks. If a public node drops, we fail over to backup providers. During congestion, watchers maintain state and deliver the webhook when the payment is finalized on-chain."}},{"@type":"Question","name":"What is idempotency and why is it critical for crypto payments?","acceptedAnswer":{"@type":"Answer","text":"Idempotency ensures that no matter how many times a specific API request or webhook is retried (due to network drops or client errors), the end result is the same. In crypto, this is vital to prevent 'double-spending' or granting a user a premium subscription twice for a single blockchain transaction."}},{"@type":"Question","name":"Can I generate unique deposit addresses for every single user?","acceptedAnswer":{"@type":"Answer","text":"recv API utilizes a smart-matching protocol rather than generating unique wallet addresses per invoice (which is expensive and difficult to sweep). We use mathematically unique decimal suffixes (e.g., 100.000123 USDT) or network-native memos (on TON) to map a single incoming transaction on your master wallet to a specific user invoice instantly."}},{"@type":"Question","name":"Is there an SDK available for Node.js or Python?","acceptedAnswer":{"@type":"Answer","text":"Currently, we provide a heavily documented, language-agnostic RESTful API that can be consumed by any modern HTTP client (Axios, Fetch, Requests). Official SDKs for TypeScript/Node.js and Go are actively in development."}},{"@type":"Question","name":"How do I verify that a webhook actually came from recv?","acceptedAnswer":{"@type":"Answer","text":"Every webhook includes an 'X-recv-Signature' header. You must use your secret Webhook Key to compute an HMAC-SHA256 hash of the raw request body. If your computed hash matches our header, the payload is authentic and untampered."}},{"@type":"Question","name":"What happens if I exceed my 50,000 monthly API requests limit?","acceptedAnswer":{"@type":"Answer","text":"We do not hard-block your API if you hit a spike. You will receive an automated alert via email and Telegram as you approach the limit (80% and 100%). Overages may be billed at a nominal rate, or you can seamlessly upgrade to the Business plan."}},{"@type":"Question","name":"Do you offer technical support for API integration?","acceptedAnswer":{"@type":"Answer","text":"Yes. Developer plan subscribers have access to prioritized email support and a dedicated developer community channel where our core engineers actively assist with architecture design and debugging."}}]}0:{"rsc":["$","$1","c",{"children":[["$","$L2",null,{"children":["$","div",null,{"className":"lend-page min-h-screen bg-black text-white selection:bg-purple-500/30","children":[["$","$3",null,{"fallback":null,"children":["$","$L4",null,{}]}],["$","$L5",null,{}],["$","div",null,{"className":"lend-backdrop lend-backdrop--grid"}],["$","div",null,{"className":"lend-backdrop lend-backdrop--glow lend-backdrop--left"}],["$","div",null,{"className":"lend-backdrop lend-backdrop--glow lend-backdrop--right"}],["$","$L6",null,{"language":"en","nav":{"products":{"title":"Products","checkout":{"title":"Checkout","desc":"High-converting payment UI"},"api":{"title":"API","desc":"Infrastructure for developers"},"invoicing":{"title":"Invoicing","desc":"Professional billing tools"},"mcp":{"title":"MCP Agent","desc":"Autonomous AI agent tools"}},"useCases":{"title":"Use Cases","tgShops":"Telegram Shops","saas":"SaaS Billing","digital":"Digital Goods","communities":"Paid Communities"},"networks":{"title":"Networks","ton":"TON","ton_usdt":"TON USDT","tron":"TRON","solana":"Solana","base":"Base","bsc":"BSC","arbitrum":"Arbitrum"},"pricing":{"title":"Pricing","merchant":"Merchant","developer":"Developer","business":"Business"},"docs":"Docs","blog":"Blog","console":"Console"}}],["$","main",null,{"className":"lend-shell relative z-10 pt-40 min-h-[calc(100vh-200px)]","children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"SoftwareApplication\",\"name\":\"recv Developer\",\"operatingSystem\":\"Web\",\"applicationCategory\":\"BusinessApplication\",\"offers\":{\"@type\":\"Offer\",\"price\":\"29.00\",\"priceCurrency\":\"USD\",\"availability\":\"https://schema.org/InStock\"}}"}}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$7"}}],"$L8","$L9","$La","$Lb","$Lc","$Ld","$Le","$Lf","$L10"]}],"$L11"]}]}],["$L12","$L13","$L14"],"$L15"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"JbTLu7-5ES5Mic2NqkdJ2"}
