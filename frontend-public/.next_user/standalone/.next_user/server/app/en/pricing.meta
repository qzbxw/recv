{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[locale]/layout,_N_T_/[locale]/pricing/layout,_N_T_/[locale]/pricing/page,_N_T_/en/pricing"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$locale/pricing/__PAGE__",
    "/$d$locale/pricing",
    "/$d$locale",
    "/_index",
    "/_head"
  ]
}