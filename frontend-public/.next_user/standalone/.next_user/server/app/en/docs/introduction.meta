{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[locale]/layout,_N_T_/[locale]/docs/layout,_N_T_/[locale]/docs/[...slug]/layout,_N_T_/[locale]/docs/[...slug]/page,_N_T_/en/docs/introduction"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$locale/docs/$c$slug/__PAGE__",
    "/$d$locale/docs/$c$slug",
    "/$d$locale/docs",
    "/$d$locale",
    "/_index",
    "/_head"
  ]
}