19:["$","p",null,{"className":"text-base md:text-[1.0625rem] leading-[1.8] text-white/60 mb-6","children":["To ensure that a webhook was actually sent by recv, you ",["$","strong",null,{"className":"font-bold text-white/90","children":"must"}]," verify the ",["$","code",null,{"className":"px-1.5 py-0.5 rounded-md bg-white/[0.06] border border-white/10 text-accent text-[0.875em] font-mono whitespace-nowrap","children":"X-recv-Signature"}]," header using your ",["$","strong",null,{"className":"font-bold text-white/90","children":"Webhook Secret"}]," as the key."]}]
1a:["$","p",null,{"className":"text-base md:text-[1.0625rem] leading-[1.8] text-white/60 mb-6","children":["The signature is computed as: ",["$","code",null,{"className":"px-1.5 py-0.5 rounded-md bg-white/[0.06] border border-white/10 text-accent text-[0.875em] font-mono whitespace-nowrap","children":"v1="}]," + HMAC-SHA256 hex digest of the string ",["$","code",null,{"className":"px-1.5 py-0.5 rounded-md bg-white/[0.06] border border-white/10 text-accent text-[0.875em] font-mono whitespace-nowrap","children":"<Timestamp>.<Raw Body>"}],"."]}]
1b:["$","h3",null,{"id":"verification-example-node-js-express","className":"text-xl md:text-2xl font-bold tracking-tight mt-10 mb-4 text-white/90 scroll-mt-32","children":"Verification Example (Node.js / Express)"}]
1c:["$","pre",null,{"className":"rounded-2xl bg-[#0a0a0c] border border-white/10 p-5 md:p-6 overflow-x-auto my-8 text-white/80 [&>code]:bg-transparent [&>code]:border-0 [&>code]:p-0 [&>code]:text-white/80","children":["$","code",null,{"className":"language-javascript","children":"const crypto = require('crypto');\n\nfunction verifyWebhook(rawBody, signature, timestamp, secret) {\n  // Compute expected signature\n  const hmac = crypto.createHmac('sha256', secret.trim());\n  hmac.update(`${timestamp}.${rawBody}`);\n  const expectedSignature = `v1=${hmac.digest('hex')}`;\n  \n  // Perform timing-safe comparison\n  return crypto.timingSafeEqual(\n    Buffer.from(signature),\n    Buffer.from(expectedSignature)\n  );\n}\n\n// Usage in Express handler:\napp.post('/webhook', express.raw({ type: 'application/json' }), (req, res) => {\n  const signature = req.headers['x-recv-signature'];\n  const timestamp = req.headers['x-recv-timestamp'];\n  const secret = process.env.RECV_WEBHOOK_SECRET;\n\n  if (!signature || !timestamp || !verifyWebhook(req.body.toString(), signature, timestamp, secret)) {\n    return res.status(401).send('invalid signature');\n  }\n\n  const payload = JSON.parse(req.body);\n  console.log(\"Processed event:\", payload.event);\n  res.status(200).send('OK');\n});\n"}]}]
1d:["$","h3",null,{"id":"verification-example-python-flask","className":"text-xl md:text-2xl font-bold tracking-tight mt-10 mb-4 text-white/90 scroll-mt-32","children":"Verification Example (Python / Flask)"}]
1e:["$","pre",null,{"className":"rounded-2xl bg-[#0a0a0c] border border-white/10 p-5 md:p-6 overflow-x-auto my-8 text-white/80 [&>code]:bg-transparent [&>code]:border-0 [&>code]:p-0 [&>code]:text-white/80","children":["$","code",null,{"className":"language-python","children":"import hashlib, hmac\nfrom flask import Flask, request, abort\n\napp = Flask(__name__)\nSECRET = \"whsec_...\".encode()\n\n@app.post(\"/webhook\")\ndef webhook():\n    signature = request.headers.get(\"X-recv-Signature\", \"\")\n    timestamp = request.headers.get(\"X-recv-Timestamp\", \"\")\n    raw_body = request.get_data()  # exact bytes\n\n    mac = hmac.new(SECRET, f\"{timestamp}.\".encode() + raw_body, hashlib.sha256)\n    expected = \"v1=\" + mac.hexdigest()\n\n    if not hmac.compare_digest(signature, expected):\n        abort(401)\n\n    event = request.get_json()\n    if event[\"event\"] == \"invoice.paid\":\n        # fulfill order for event[\"invoice\"][\"public_id\"]\n        ...\n    return \"ok\", 200\n"}]}]
1f:["$","blockquote",null,{"className":"border-l-2 border-accent/40 pl-6 py-1 my-8 text-white/70 italic [&>p]:mb-0","children":["\n",["$","p",null,{"className":"text-base md:text-[1.0625rem] leading-[1.8] text-white/60 mb-6","children":["Always HMAC over the ",["$","strong",null,{"className":"font-bold text-white/90","children":"raw request bytes"}],", not a re-serialized JSON object — re-encoding can change key order or whitespace and break the signature."]}],"\n"]}]
