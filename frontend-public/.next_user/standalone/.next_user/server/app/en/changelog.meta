{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[locale]/layout,_N_T_/[locale]/changelog/layout,_N_T_/[locale]/changelog/page,_N_T_/en/changelog"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$locale/changelog/__PAGE__",
    "/$d$locale/changelog",
    "/$d$locale",
    "/_index",
    "/_head"
  ]
}