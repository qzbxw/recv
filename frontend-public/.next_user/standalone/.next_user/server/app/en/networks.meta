{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[locale]/layout,_N_T_/[locale]/networks/layout,_N_T_/[locale]/networks/page,_N_T_/en/networks"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$locale/networks/__PAGE__",
    "/$d$locale/networks",
    "/$d$locale",
    "/_index",
    "/_head"
  ]
}