{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[locale]/layout,_N_T_/[locale]/products/layout,_N_T_/[locale]/products/invoicing/layout,_N_T_/[locale]/products/invoicing/page,_N_T_/ru/products/invoicing"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$locale/products/invoicing/__PAGE__",
    "/$d$locale/products/invoicing",
    "/$d$locale/products",
    "/$d$locale",
    "/_index",
    "/_head"
  ]
}