{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[locale]/layout,_N_T_/[locale]/use-cases/layout,_N_T_/[locale]/use-cases/page,_N_T_/ru/use-cases"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$locale/use-cases/__PAGE__",
    "/$d$locale/use-cases",
    "/$d$locale",
    "/_index",
    "/_head"
  ]
}