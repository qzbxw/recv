{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[locale]/layout,_N_T_/[locale]/networks/layout,_N_T_/[locale]/networks/[network]/layout,_N_T_/[locale]/networks/[network]/page,_N_T_/ru/networks/base"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$locale/networks/$d$network/__PAGE__",
    "/$d$locale/networks/$d$network",
    "/$d$locale/networks",
    "/$d$locale",
    "/_index",
    "/_head"
  ]
}