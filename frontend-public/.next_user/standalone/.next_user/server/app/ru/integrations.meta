{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[locale]/layout,_N_T_/[locale]/integrations/layout,_N_T_/[locale]/integrations/page,_N_T_/ru/integrations"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$locale/integrations/__PAGE__",
    "/$d$locale/integrations",
    "/$d$locale",
    "/_index",
    "/_head"
  ]
}